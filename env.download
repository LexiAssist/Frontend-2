# LexiAssist Frontend - Development Environment

# Disable Mock Mode - Connect to Real Backend
NEXT_PUBLIC_USE_MOCK_API=false
NEXT_PUBLIC_MOCK_MODE=false

# API Gateway URL (Go Backend)
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080

# AI Service URL (Route through Gateway for security)
NEXT_PUBLIC_AI_PROXY_URL=http://localhost:8080

# WebSocket URL for Real-Time Sync
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Ingestion Service URL (for direct material processing)
NEXT_PUBLIC_INGESTION_URL=http://localhost:5002

# Database URL (Server-side only, not exposed to client)
DATABASE_URL=postgresql://lexiassist:lexiassist_secret@localhost:5432/lexiassist
